{
  "version": "1.0.0",
  "description": "One-sentence product benchmark set for Rebot production-grade evaluation.",
  "cases": [
    {
      "id": "game_cheese_run_web",
      "prompt": "做一个奶酪迷宫小游戏，支持WASD移动、计分、失败重开和移动端适配。",
      "framework": "react",
      "expected_files": [
        "package.json",
        "index.html",
        "src/main.tsx",
        "src/App.tsx"
      ],
      "expected_keywords": [
        "score",
        "restart",
        "keydown",
        "touch",
        "responsive"
      ]
    },
    {
      "id": "task_todo_flutter",
      "prompt": "一句话生成一个可用的待办应用，含新增/完成/删除/筛选和本地持久化。",
      "framework": "flutter",
      "expected_files": [
        "pubspec.yaml",
        "lib/main.dart"
      ],
      "expected_keywords": [
        "add",
        "delete",
        "complete",
        "filter",
        "storage"
      ]
    },
    {
      "id": "dashboard_admin_react",
      "prompt": "生成一个库存管理后台：列表、搜索、分页、编辑弹窗、表单校验。",
      "framework": "react",
      "expected_files": [
        "package.json",
        "index.html",
        "src/main.tsx",
        "src/App.tsx"
      ],
      "expected_keywords": [
        "table",
        "search",
        "pagination",
        "modal",
        "validation"
      ]
    },
    {
      "id": "cli_assistant_python",
      "prompt": "做一个命令行记账工具，支持新增记录、分类统计、导出csv和错误处理。",
      "framework": "python",
      "expected_files": [
        "requirements.txt",
        "main.py"
      ],
      "expected_keywords": [
        "argparse",
        "csv",
        "error",
        "summary",
        "category"
      ]
    },
    {
      "id": "landing_conversion_html",
      "prompt": "做一个产品落地页：主卖点、定价区、FAQ、表单收集和移动端布局。",
      "framework": "html",
      "expected_files": [
        "index.html"
      ],
      "expected_keywords": [
        "pricing",
        "faq",
        "form",
        "mobile",
        "cta"
      ]
    }
  ]
}
